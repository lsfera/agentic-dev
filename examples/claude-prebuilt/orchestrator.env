# Use case: run autonomously with Claude, using the prebuilt GHCR inner image —
# no local docker build. Copy to .sandcastle/orchestrator.env and fill GH_TOKEN.

# Orchestrator's gh token (issue list/label/comment, PR create). Host: `gh auth token`.
GH_TOKEN=

# Prebuilt Claude inner image (skips the local build). `:latest` tracks the
# newest publish; to pin a release instead, resolve its tag with:
#   curl -s https://api.github.com/repos/lsfera/agentic-dev/releases | jq -r '.[0].tag_name | ltrimstr("v")'
SANDCASTLE_IMAGE=ghcr.io/lsfera/agentic-dev/sandbox:latest

# Optional: target another repo (default: the repo gh detects from the cwd).
# AGENTIC_REPO=owner/name
