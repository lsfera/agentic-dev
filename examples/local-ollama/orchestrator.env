# Use case: offline / no API cost — implement with a local Ollama model via
# opencode instead of Claude. Copy to .sandcastle/orchestrator.env, fill GH_TOKEN.
# (No CLAUDE_CODE_OAUTH_TOKEN needed for the local tier.)

# Orchestrator's gh token (issue list/label/comment, PR create). Host: `gh auth token`.
GH_TOKEN=

# Use the local (opencode + host Ollama) tier.
AGENTIC_TIER=local

# opencode model ref (ollama/<model>); the model must exist in `ollama list` and
# be declared in opencode.json. Swap for e.g. ollama/qwen2.5-coder:32b.
AGENTIC_LOCAL_MODEL=ollama/qwen3-coder:30b

# Prebuilt opencode inner image (skips the local build).
SANDCASTLE_OPENCODE_IMAGE=ghcr.io/lsfera/agentic-dev/sandbox-opencode:latest
