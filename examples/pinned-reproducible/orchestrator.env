# Use case: reproducible runs — pin the inner images to a specific release tag
# instead of floating :latest. Replace v0.1.3 with the release you want; resolve
# the newest with:
#   curl -s https://api.github.com/repos/lsfera/agentic-dev/releases | jq -r '.[0].tag_name'
# Copy to .sandcastle/orchestrator.env and fill GH_TOKEN.

# Orchestrator's gh token (issue list/label/comment, PR create). Host: `gh auth token`.
GH_TOKEN=

# Pinned inner images.
SANDCASTLE_IMAGE=ghcr.io/lsfera/agentic-dev/sandbox:v0.1.3
SANDCASTLE_OPENCODE_IMAGE=ghcr.io/lsfera/agentic-dev/sandbox-opencode:v0.1.3
