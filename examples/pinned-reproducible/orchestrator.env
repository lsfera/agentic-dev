# Use case: reproducible runs — pin the inner images to a specific release tag
# instead of floating :latest. Image tags drop the release's "v" (release v0.2.0 →
# image tag 0.2.0). Replace 0.2.0 below with the release you want; resolve the
# newest with:
#   curl -s https://api.github.com/repos/lsfera/agentic-dev/releases | jq -r '.[0].tag_name | ltrimstr("v")'
# Copy to .sandcastle/orchestrator.env and fill GH_TOKEN.

# Orchestrator's gh token (issue list/label/comment, PR create). Host: `gh auth token`.
GH_TOKEN=

# Pinned inner images.
SANDCASTLE_IMAGE=ghcr.io/lsfera/agentic-dev/sandbox:0.2.0
SANDCASTLE_OPENCODE_IMAGE=ghcr.io/lsfera/agentic-dev/sandbox-opencode:0.2.0
