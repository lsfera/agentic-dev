# Use case: work many ready-for-agent issues at once. Each issue still runs in its
# own disposable sandbox; AGENTIC_CONCURRENCY caps how many run in parallel.
# Copy to .sandcastle/orchestrator.env and fill GH_TOKEN.

# Orchestrator's gh token (issue list/label/comment, PR create). Host: `gh auth token`.
GH_TOKEN=

# Prebuilt Claude inner image (skips the local build).
SANDCASTLE_IMAGE=ghcr.io/lsfera/agentic-dev/sandbox:latest

# Run up to 4 sandboxes concurrently. Size to host RAM/CPU — each sandbox is a
# full container; the local Ollama tier especially is memory-bound (one model
# load per concurrent sandbox).
AGENTIC_CONCURRENCY=4
