# Template for .devcontainer/.env
# Generated automatically by init.sh — do not commit this file.
# Copy to .env and adjust if you need non-default values.

# Absolute path to your SSH keys (read-only bind mount for git access).
SSH_DIR=/Users/CHANGE_ME/.ssh

# Claude Code config, memory, and MCP registrations persist here across rebuilds.
CLAUDE_PERSIST_HOST_DIR=/Users/CHANGE_ME/.devcontainer-claude

# Docker socket path (bind-mounted into the container; the docker-outside-of-docker
# feature installs the CLI and fixes its permissions at startup).
# Docker Desktop (macOS/Windows): /var/run/docker.sock
# Rootless Docker on Linux:       /run/user/<UID>/docker.sock
DOCKER_SOCK=/var/run/docker.sock

# Set by init.sh on every open — do not edit manually.
LOCAL_WORKSPACE_FOLDER=/path/to/leo
WORKSPACE_FOLDER=/workspaces/leo
