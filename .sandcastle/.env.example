# Copy to .sandcastle/.env (gitignored) and fill in.
# Sandcastle auto-resolves .sandcastle/.env into the inner sandbox.

# Claude Code OAuth token — mint on the host with `claude setup-token`.
# Lets the agent use your Claude subscription instead of an API key (ADR-0003).
CLAUDE_CODE_OAUTH_TOKEN=

# Alternative: an Anthropic API key instead of the subscription token.
# ANTHROPIC_API_KEY=
