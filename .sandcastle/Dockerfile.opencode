FROM node:22-bookworm

# Lean inner image for the local Ollama tier (ADR-0002 / issue #7).
# Same base as Dockerfile but ships opencode CLI instead of Claude Code.
RUN apt-get update && apt-get install -y \
  git \
  curl \
  && rm -rf /var/lib/apt/lists/*

# Build-args for UID/GID alignment — must match sandcastle's defaults (1000).
ARG AGENT_UID=1000
ARG AGENT_GID=1000

# Rename the base image's "node" user to "agent" and align UID/GID.
RUN groupmod -o -g $AGENT_GID node && usermod -o -u $AGENT_UID -g $AGENT_GID -d /home/agent -m -l agent node

# Install opencode CLI globally (as root so the binary lands in /usr/local/bin
# and is accessible by the agent user without PATH changes). The npm package is
# published as "opencode-ai"; it installs the `opencode` binary.
RUN npm install -g opencode-ai

# Label-scoped orphan sweep (#8/#19): both inner-image variants must carry this
# so sweepOrphanedSandboxes() can reap crashed local-tier sandboxes too.
LABEL "agentic.sandbox"="1"

USER ${AGENT_UID}:${AGENT_GID}

WORKDIR /home/agent

# In branch/worktree mode sandcastle bind-mounts the git worktree at
# /home/agent/workspace and sets it as the working directory at container start.
ENTRYPOINT ["sleep", "infinity"]
