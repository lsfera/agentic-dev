# Copy to .sandcastle/orchestrator.env (gitignored) and fill in.
#
# This file holds secrets the ORCHESTRATOR process itself needs (its gh API
# calls), sourced by /afk into the orchestrator's shell. It is deliberately
# SEPARATE from .sandcastle/.env: sandcastle auto-injects .sandcastle/.env into
# every inner sandbox, but the agent must NOT get the GitHub token (it does not
# push or open PRs in slice 1 — the orchestrator does). Keeping GH_TOKEN here
# keeps it out of the sandboxes.

# GitHub token for gh (issue list/label/comment, PR create). On the host:
#   gh auth token
# then paste the value here. Needs repo scope on lsfera/agentic-dev.
GH_TOKEN=
